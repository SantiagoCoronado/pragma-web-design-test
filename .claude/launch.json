{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Next.js Dev Server (Turbo)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--turbopack"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
